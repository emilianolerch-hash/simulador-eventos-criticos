DATABASE_URL=postgresql://postgres@localhost:5432/simulador_db
JWT_SECRET_KEY=cambia-esto-en-produccion-usa-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Entorno: development (permite JWT fallback) | production (JWT_SECRET_KEY obligatorio)
ENV=development

# CORS: origins permitidos separados por coma
CORS_ORIGINS=http://localhost:3000

# Rate limiting (requests por minuto por IP)
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5

# Secret para promover usuarios a rol 'validator' (POST /auth/promote)
# Generá uno con: openssl rand -hex 32
ADMIN_SECRET=cambia-esto-en-produccion
