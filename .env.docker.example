# Copiá este archivo como .env.docker y completá los valores antes de correr docker compose.
# Generá JWT_SECRET_KEY con: openssl rand -hex 32

JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ENV=production

# URL del backend que el BROWSER va a usar (se bake en el build del frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS: URLs permitidas para llamar al backend (separadas por coma)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (requests por minuto por IP)
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# PostgreSQL (opcional — la imagen usa trust auth por defecto)
# POSTGRES_PASSWORD=
# POSTGRES_HOST_AUTH_METHOD=trust
